{
  "name": "mcp-yandex-direct",
  "version": "1.0.7",
  "description": "MCP server for the Yandex Direct API v5 — manage PPC campaigns, ad groups, ads, keywords and pull statistics from AI agents.",
  "mcpName": "io.github.gistrec/mcp-yandex-direct",
  "type": "module",
  "bin": {
    "mcp-yandex-direct": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.check.json",
    "smoke": "node --import tsx src/smoke.ts",
    "integration": "node --import tsx src/integration.ts",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "yandex",
    "yandex-direct",
    "advertising",
    "ppc"
  ],
  "license": "MIT",
  "author": "Aleksandr Kovalko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gistrec/mcp-yandex-direct.git"
  },
  "homepage": "https://github.com/gistrec/mcp-yandex-direct#readme",
  "bugs": {
    "url": "https://github.com/gistrec/mcp-yandex-direct/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  }
}
